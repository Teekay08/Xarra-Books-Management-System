# Database
DATABASE_URL=postgres://xarra:xarra@localhost:5433/xarra

# Redis
REDIS_URL=redis://localhost:6379

# API
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Auth (Better Auth)
JWT_SECRET=change-this-to-a-secure-random-string
BETTER_AUTH_SECRET=change-this-to-a-secure-random-string-min-32-chars
BETTER_AUTH_URL=http://localhost:3001

# CORS
CORS_ORIGIN=http://localhost:5173

# AWS (Production only)
AWS_REGION=af-south-1
S3_BUCKET=xarra-documents

# Email (Resend)
RESEND_API_KEY=
FROM_EMAIL=noreply@xarrabooks.com

# Takealot (Post-MVP)
TAKEALOT_API_KEY=

# WooCommerce (xarrabooks.com real-time sync)
# Consumer key/secret: WooCommerce > Settings > Advanced > REST API > Add Key
# Webhook secret: any random string — paste the same value when creating webhooks in WooCommerce
WOOCOMMERCE_URL=https://xarrabooks.com
WOOCOMMERCE_CONSUMER_KEY=ck_
WOOCOMMERCE_CONSUMER_SECRET=cs_
WOOCOMMERCE_WEBHOOK_SECRET=
