{
  "family": "xarra-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::role/xarra-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::role/xarra-api-task-role",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "<AWS_ACCOUNT_ID>.dkr.ecr.af-south-1.amazonaws.com/xarra-api:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3001" },
        { "name": "HOST", "value": "0.0.0.0" },
        { "name": "CORS_ORIGIN", "value": "https://app.xarrabooks.com" },
        { "name": "WEB_URL", "value": "https://app.xarrabooks.com" },
        { "name": "AWS_REGION", "value": "af-south-1" },
        { "name": "S3_BUCKET", "value": "xarra-documents" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:af-south-1::secret:xarra/database-url"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:secretsmanager:af-south-1::secret:xarra/redis-url"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:af-south-1::secret:xarra/jwt-secret"
        },
        {
          "name": "RESEND_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:af-south-1::secret:xarra/resend-api-key"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/xarra-api",
          "awslogs-region": "af-south-1",
          "awslogs-stream-prefix": "api"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:3001/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
